{
  "appId": "com.pangman.nasty",
  "appName": "Nasty",
  "webDir": "www",
  "backgroundColor": "#0e3421",
  "ios": {
    "scrollEnabled": false,
    "contentInset": "never",
    "backgroundColor": "#0e3421",
    "allowsLinkPreview": false
  },
  "plugins": {
    "SplashScreen": {
      "launchShowDuration": 700,
      "launchAutoHide": true,
      "backgroundColor": "#0e3421",
      "showSpinner": false,
      "splashFullScreen": true,
      "splashImmersive": true
    },
    "StatusBar": {
      "style": "LIGHT",
      "overlaysWebView": false,
      "backgroundColor": "#0e3421"
    }
  }
}
